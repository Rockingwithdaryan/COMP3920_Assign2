<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' · Chatter' : 'Chatter' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% if (user) { %>
  <nav class="navbar">
    <a href="/groups" class="nav-brand">💬 Chatter</a>
    <div class="nav-user">
      <span class="nav-username">@<%= user.username %></span>
      <a href="/auth/logout" class="btn btn-sm btn-ghost">Log out</a>
    </div>
  </nav>
  <% } %>
  <main class="main-content">
