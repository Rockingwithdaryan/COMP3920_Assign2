<%- include('../partials/header', { title: 'Your Chats' }) %>

<div class="page-container">
  <div class="page-header">
    <div>
      <h1>Your Chats</h1>
      <p class="text-muted"><%= groupCount %> group<%= groupCount !== 1 ? 's' : '' %></p>
    </div>
    <a href="/groups/create" class="btn btn-primary">+ New Group</a>
  </div>

  <% if (groups.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">💬</div>
      <h3>No chats yet</h3>
      <p>Create a new group to start chatting!</p>
      <a href="/groups/create" class="btn btn-primary">Create a group</a>
    </div>
  <% } else { %>
    <div class="group-list">
      <% groups.forEach(group => { %>
        <a href="/groups/<%= group.id %>" class="group-card">
          <div class="group-avatar"><%= group.name.charAt(0).toUpperCase() %></div>
          <div class="group-info">
            <div class="group-name"><%= group.name %></div>
            <div class="group-meta text-muted">
              <% if (group.last_message_at) { %>
                Last message: <%= new Date(group.last_message_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              <% } else { %>
                No messages yet
              <% } %>
            </div>
          </div>
          <% if (group.unread_count > 0) { %>
            <span class="unread-badge"><%= group.unread_count %></span>
          <% } %>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
